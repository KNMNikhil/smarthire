# SmartHire Backend Environment Variables (Production)

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Get from Render PostgreSQL)
DB_HOST=your-database-host.render.com
DB_PORT=5432
DB_NAME=smarthire_db
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# OR use single DATABASE_URL (Render provides this)
# DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_FOR_PRODUCTION
JWT_EXPIRE=7d

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (Update after frontend deployment)
CLIENT_URL=https://your-frontend-url.onrender.com

# Optional: OpenRouter API for AI Resume (if using)
OPENROUTER_API_KEY=your_openrouter_api_key